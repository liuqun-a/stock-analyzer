#!/bin/bash
# Git Pre-commit Hook - 敏感信息检查
# 在每次 commit 前自动检查是否包含敏感信息

set -e

echo "🔍 运行敏感信息检查..."
echo ""

# 获取暂存区文件
FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$FILES" ]; then
    echo "✅ 没有文件需要检查"
    exit 0
fi

echo "📋 检查以下文件:"
echo "$FILES"
echo ""

# 运行检查脚本
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
python3 "$SCRIPT_DIR/scripts/check_secrets.py" $FILES

CHECK_RESULT=$?

if [ $CHECK_RESULT -ne 0 ]; then
    echo ""
    echo "🚨 发现敏感信息！"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "⚠️  提交被阻止，原因：文件中包含敏感信息"
    echo ""
    echo "📝 请执行以下操作："
    echo "   1. 检查上述文件中的敏感信息"
    echo "   2. 移除或替换敏感信息"
    echo "   3. 重新添加文件：git add <file>"
    echo "   4. 重新提交：git commit"
    echo ""
    echo "💡 如果确认是误报，可以添加白名单："
    echo "   编辑 scripts/check_secrets.py 中的 WHITELIST_PATTERNS"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "❌ 提交已阻止"
    exit 1
fi

echo ""
echo "✅ 敏感信息检查通过"
echo ""

# 继续其他检查（如果有）
exit 0
